---
import Navigation from '../components/Navigation.jsx';
import '../index.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	schema?: object | object[];
	hideFooterNewsletter?: boolean;
	robots?: string;
}

const {
	title,
	description = "Lead Software Engineer specializing in AI engineering, automation architecture, and production AI systems.",
	image,
	type = 'website',
	publishedTime,
	schema,
	hideFooterNewsletter = false,
	robots = 'index, follow',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname.toLowerCase().replace(/\.html$/, ''), Astro.site);
const imageURL = new URL(image || '/images/og-default.png', Astro.site);

const portfolioData = {
  name: "Collin Wilkins",
  email: "wilkins507@gmail.com",
  linkedin: "https://www.linkedin.com/in/collin-wilkins-1020215a/",
  github: "https://github.com/cwilkins507"
};

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="google-site-verification" content="p-TMFQiYQvWsK5Tn417NrhsVXZUOlO0riWjvgMm-zSI" />

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageURL} />
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@CollinWilkins7" />
		<meta name="twitter:creator" content="@CollinWilkins7" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={imageURL} />

		<link rel="canonical" href={canonicalURL} />

		<!-- Google Fonts: Newsreader + IBM Plex Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<!-- JSON-LD Structured Data -->
		{schema && (
			Array.isArray(schema) ? (
				schema.map((s) => (
					<script type="application/ld+json" set:html={JSON.stringify(s)} />
				))
			) : (
				<script type="application/ld+json" set:html={JSON.stringify(schema)} />
			)
		)}

		<!-- URL normalisation: strip .html, lowercase -->
		<script is:inline>
			(function(){
				var path = window.location.pathname;
				var canonical = path.replace(/\.html$/, '').toLowerCase();
				if (canonical !== path) {
					window.location.replace(canonical + window.location.search + window.location.hash);
				}
			})();
		</script>

		<!-- Plausible Analytics -->
		<script async src="https://plausible.io/js/pa-CmOP0LRtv6tlswXjVukB6.js"></script>
		<script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()</script>
	</head>
	<body>
		<Navigation portfolioData={portfolioData} client:load />

		<main id="page-content">
			<slot />
		</main>

		<!-- Footer -->
		<footer style="border-top: 1px solid var(--rule);">
			<!-- Newsletter strip (footer-only) -->
			{!hideFooterNewsletter && (
				<div style="background: var(--paper-2); border-bottom: 1px solid var(--rule);">
					<div class="wrap" style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;padding-top:22px;padding-bottom:22px;">
						<p style="font-size:15px;line-height:1.5;color:var(--ink-soft);max-width:54ch;">
							Not ready to talk? <strong style="color:var(--ink);font-weight:600;">Read along.</strong> Practical AI engineering — patterns, trade-offs, and the occasional self-hosting experiment.
						</p>
						<form
							action="https://buttondown.com/api/emails/embed-subscribe/collinwilkins"
							method="post"
							target="popupwindow"
							style="display:flex;gap:10px;flex-shrink:0;"
						>
							<input
								type="email"
								name="email"
								placeholder="you@company.com"
								aria-label="Email address"
								style="border:1px solid var(--rule);border-radius:999px;padding:11px 18px;background:var(--paper);font-family:var(--mono);font-size:13px;color:var(--ink);width:min(220px,55vw);outline:none;"
							/>
							<button type="submit" class="btn btn-ghost">Subscribe</button>
						</form>
					</div>
				</div>
			)}

			<!-- 4-column footer links -->
			<div style={`max-width:var(--maxw);margin:0 auto;padding:clamp(36px,5vw,52px) clamp(20px,5vw,48px) 0;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:24px;`}>
				<div>
					<div style="font-size:18px;font-weight:600;letter-spacing:-.01em;">{portfolioData.name}</div>
					<p style="font-size:13.5px;line-height:1.5;color:var(--ink-soft);max-width:32ch;margin-top:10px;">
						AI engineering training, workshops, and advisory for teams shipping in high-stakes environments.
					</p>
				</div>
				<div>
					<h4 style="font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:15px;">Work</h4>
					<ul style="list-style:none;">
						<li style="margin-bottom:10px;"><a href="/services" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">Training</a></li>
						<li style="margin-bottom:10px;"><a href="/services" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">Advisory</a></li>
					</ul>
				</div>
				<div>
					<h4 style="font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:15px;">Writing</h4>
					<ul style="list-style:none;">
						<li style="margin-bottom:10px;"><a href="/articles" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">Articles</a></li>
						<li style="margin-bottom:10px;"><a href="https://buttondown.com/collinwilkins" target="_blank" rel="noopener noreferrer" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">Newsletter</a></li>
					</ul>
				</div>
				<div>
					<h4 style="font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:15px;">Elsewhere</h4>
					<ul style="list-style:none;">
						<li style="margin-bottom:10px;"><a href={portfolioData.linkedin} target="_blank" rel="noopener noreferrer" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">LinkedIn</a></li>
						<li style="margin-bottom:10px;"><a href={portfolioData.github} target="_blank" rel="noopener noreferrer" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">GitHub</a></li>
						<li style="margin-bottom:10px;"><a href="https://x.com/CollinWilkins7" target="_blank" rel="noopener noreferrer" style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);text-decoration:none;letter-spacing:.02em;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-soft)'">Twitter / X</a></li>
					</ul>
				</div>
			</div>

			<div style={`max-width:var(--maxw);margin:0 auto;padding:28px clamp(20px,5vw,48px) 20px;font-family:var(--mono);font-size:11px;color:var(--ink-faint);letter-spacing:.04em;`}>
				© {currentYear} Collin Wilkins · Detroit, MI
			</div>
		</footer>
	</body>
</html>

<style>
	@media (max-width: 760px) {
		footer > div:first-child + div {
			grid-template-columns: 1fr 1fr !important;
		}
	}
</style>
