---
import Layout from '../layouts/Layout.astro';
import About from '../components/About';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Collin Wilkins",
  "jobTitle": "Lead Software Engineer",
  "description": "Lead Software Engineer with 12 years across enterprise engineering, finance, and business operations. Writes about AI coding tools, convention files, automation architecture, and production systems.",
  "url": "https://collinwilkins.com",
  "sameAs": [
    "https://www.linkedin.com/in/collin-wilkins-1020215a/",
    "https://github.com/cwilkins507",
    "https://x.com/CollinWilkins7"
  ],
  "knowsAbout": [
    "Python",
    "AWS",
    "Serverless Architecture",
    "AI Integration",
    "AI Coding Tools",
    "Claude Code",
    "Convention Files",
    "Context Engineering",
    "Automation",
    "Automation Architecture",
    "Event-Driven Systems",
    "Software Architecture"
  ],
  "alumniOf": [
    {
      "@type": "Organization",
      "name": "Ford Motor Company"
    }
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Morningstar"
  }
};
---

<Layout
  title="About Collin Wilkins | AI Tooling, Automation Architecture, and Engineering Systems"
  description="Lead Software Engineer writing about AI coding tools, convention files, automation architecture, and production systems. Previously Ford Motor Company, now Morningstar."
  schema={personSchema}
>
	<About />
</Layout>
