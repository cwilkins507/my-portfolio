---
import Layout from '../layouts/Layout.astro';
import About from '../components/About';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Collin Wilkins",
  "jobTitle": "Lead Software Engineer",
  "description": "Lead Software Engineer with a background across Ford finance, pricing, field work, connected vehicle systems, and Morningstar compliance software.",
  "url": "https://collinwilkins.com",
  "sameAs": [
    "https://www.linkedin.com/in/collin-wilkins-1020215a/",
    "https://github.com/cwilkins507",
    "https://x.com/CollinWilkins7"
  ],
  "knowsAbout": [
    "Python",
    "AWS",
    "Serverless Architecture",
    "AI Integration",
    "AI Coding Tools",
    "Claude Code",
    "Convention Files",
    "Context Engineering",
    "Automation",
    "Automation Architecture",
    "Event-Driven Systems",
    "Software Architecture"
  ],
  "alumniOf": [
    {
      "@type": "Organization",
      "name": "Ford Motor Company"
    }
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Morningstar"
  }
};
---

<Layout
  title="About Collin Wilkins | From Ford Finance to Software Engineering"
  description="The personal backstory behind Collin Wilkins: Ford pricing, four Excel files, Raptor, field work, and the move into engineering."
  schema={personSchema}
>
	<About />
</Layout>
