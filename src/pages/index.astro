---
import Layout from '../layouts/Layout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import BookCTA from '../components/BookCTA.astro';
import { FUNNEL_MODE, BOOKING_HREF } from '../data/site.js';
import { getCategoryForArticle } from '../data/categories.js';

const articleModules = import.meta.glob('../articles/*.md', { eager: true });
const allArticles = Object.entries(articleModules).map(([file, article]) => ({
  slug: file.split('/').pop().replace('.md', ''),
  ...article.frontmatter,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const totalArticles = allArticles.length;

// Featured 3 for "Selected writing" section
const FEATURED_SLUGS = [
  'context-engineering-ai-coding-tools',
  'llm-gateway-architecture',
  'claude-code-productivity-paradox',
];
const featuredArticles = FEATURED_SLUGS
  .map(slug => allArticles.find(a => a.slug === slug))
  .filter(Boolean);

const credibilitySignals = [
  `12 years across Ford & Morningstar`,
  '$5M saved via connected-vehicle automation',
  `${totalArticles} published articles`,
  'Lead Engineer, currently shipping production AI',
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Collin Wilkins',
  url: 'https://collinwilkins.com',
  description: 'AI engineering training, workshops, and advisory for teams shipping AI in regulated, high-stakes environments.',
  author: { '@type': 'Person', name: 'Collin Wilkins', url: 'https://collinwilkins.com' },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Collin Wilkins',
  jobTitle: 'Lead Software Engineer',
  description: 'Lead Software Engineer with 12 years across Ford Motor Company and Morningstar. AI engineering training, workshops, and advisory.',
  url: 'https://collinwilkins.com',
  image: 'https://collinwilkins.com/images/profile_photo.png',
  sameAs: [
    'https://www.linkedin.com/in/collin-wilkins-1020215a/',
    'https://github.com/cwilkins507',
  ],
};

const LOGOS = [
  { cls: 'l-morningstar', mk: 'circle', name: 'Morningstar' },
  { cls: 'l-ford', mk: 'none', name: 'Ford', italic: true },
  { cls: 'l-finimbus', mk: 'diamond', name: 'FiNimbus' },
  { cls: 'l-connected', mk: 'dashed', name: 'Connected Vehicle' },
  { cls: 'l-cw', mk: 'square', name: 'collinwilkins.com', mono: true },
];

function readTime(article) {
  return article.readTime || '5 min';
}
---

<Layout
  title="Collin Wilkins — AI Engineering Training, Workshops & Advisory"
  description="AI engineering training, workshops, and advisory for teams putting AI into production in regulated, high-stakes environments. Lead Software Engineer at Morningstar."
  schema={[websiteSchema, personSchema]}
  hideFooterNewsletter={false}
>

<!-- ══════════════════════════════════════
     HERO
══════════════════════════════════════ -->
<header class="hero">
  <div class="wrap hero-grid">
    <div class="hero-main">
      <span class="eyebrow">Training · Workshops · Advisory</span>
      <h1>Ship AI features your team can actually maintain.</h1>
      <p class="hero-sub">
        Hands-on training, workshops, and advisory for engineering teams putting AI into production in regulated, high-stakes environments.
        I'm Collin Wilkins — a lead engineer who ships this work in production, then gets <em>your</em> engineers doing it on <em>your</em> codebase.
      </p>
      <div class="hero-actions">
        <BookCTA />
        <a href="#writing" class="btn btn-ghost">See my writing</a>
      </div>
      <p class="hero-reassure">A 30-minute call — no pitch. Leave with your highest-leverage AI use case mapped.</p>
    </div>

    <aside class="hilite" aria-label="About the author">
      <div class="hi-top">
        <div class="hi-pic">
          <img
            src="/images/profile_photo.webp"
            alt="Collin Wilkins"
            width="64"
            height="64"
            style="width:100%;height:100%;object-fit:cover;border-radius:50%;"
            onerror="this.style.display='none'"
          />
        </div>
        <div>
          <div class="hi-name">Collin Wilkins</div>
          <div class="hi-tag">Business operator turned software engineer.</div>
        </div>
      </div>
      <ul class="hi-stats">
        {credibilitySignals.map(signal => (
          <li><span class="s">/</span><span>{signal}</span></li>
        ))}
      </ul>
    </aside>
  </div>
</header>

<!-- ══════════════════════════════════════
     LOGO STRIP
══════════════════════════════════════ -->
<div class="logos">
  <div class="cap">Built &amp; shipped at</div>
  <div class="marquee">
    <div class="track" aria-hidden="false">
      <span class="logo-img"><img src="/images/logos/morningstar.svg" alt="Morningstar" class="logo-asset" /></span>
      <span class="logo-img"><img src="/images/logos/ford-credit.png" alt="Ford Credit" class="logo-asset logo-asset-light-bg" /></span>
      <span class="logo-img"><img src="/images/logos/finimbus.png" alt="FiNimbus" class="logo-asset logo-asset-light-bg" /></span>
      <span class="logo l-connected"><span class="mk mk-dashed"></span>Connected Vehicle</span>
    </div>
    <div class="track" aria-hidden="true">
      <span class="logo-img"><img src="/images/logos/morningstar.svg" alt="Morningstar" class="logo-asset" /></span>
      <span class="logo-img"><img src="/images/logos/ford-credit.png" alt="Ford Credit" class="logo-asset logo-asset-light-bg" /></span>
      <span class="logo-img"><img src="/images/logos/finimbus.png" alt="FiNimbus" class="logo-asset logo-asset-light-bg" /></span>
      <span class="logo l-connected"><span class="mk mk-dashed"></span>Connected Vehicle</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SELECTED WRITING
══════════════════════════════════════ -->
<section class="band" id="writing">
  <div class="wrap">
    <div class="section-head">
      <h2>Selected writing</h2>
      <a href="/articles" class="label" style="color:var(--ink-faint);text-decoration:none;">All {totalArticles} articles →</a>
    </div>
    <div class="articles-grid">
      {featuredArticles.map(article => (
        <a href={`/articles/${article.slug}`} class="article">
          <div class="meta">
            <span class="cat">{getCategoryForArticle(article.tags)}</span>
            <span class="min">{readTime(article)}</span>
          </div>
          <h3>{article.title}</h3>
          <p>{article.excerpt}</p>
          <span class="read">Read →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     ABOUT
══════════════════════════════════════ -->
<section class="band" id="about">
  <div class="wrap about-grid">
    <h2>I've shipped this work, not just talked about it.</h2>
    <div class="about-body">
      <p>I'm a lead engineer at <strong>Morningstar</strong> working in regulated financial services, where AI features have to be correct, explainable, and maintainable — not just impressive in a demo.</p>
      <p>Before that I spent three years on <strong>Ford's connected-vehicle team</strong> and came up through a leadership development program with a background spanning sales and operations. That mix is why I run training the way I do: technical depth, always tied to the business call underneath it.</p>
      <p>I write about AI engineering at collinwilkins.com, and I work with a small number of teams at a time so the engagement stays hands-on.</p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     CLOSING CTA (hybrid: soft variant)
══════════════════════════════════════ -->
<ClosingCTA variant="soft" />

</Layout>

<style>
/* ---- Hero ---- */
.hero {
  padding: clamp(52px, 7vw, 92px) 0 clamp(40px, 5vw, 60px);
}
.hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(36px, 5vw, 56px);
  align-items: center;
}
@media (min-width: 940px) {
  .hero-grid {
    grid-template-columns: minmax(0, 1.32fr) minmax(310px, .86fr);
    gap: clamp(40px, 5vw, 68px);
  }
}
.eyebrow {
  display: inline-block;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--rule);
  border-radius: 999px;
  padding: 8px 15px;
  margin-bottom: 28px;
  background: var(--paper-2);
}
.hero h1 {
  font-size: clamp(36px, 5.6vw, 64px);
  line-height: 1.02;
  font-weight: 500;
  letter-spacing: -.02em;
  max-width: 14ch;
  text-wrap: balance;
}
.hero-sub {
  font-size: clamp(17px, 2vw, 20px);
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 52ch;
  margin-top: 26px;
  text-wrap: pretty;
}
.hero-sub em { font-style: italic; color: var(--ink); }
.hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 32px;
}
.hero-reassure {
  font-family: var(--mono);
  font-size: 12.5px;
  line-height: 1.5;
  color: var(--ink-faint);
  margin-top: 18px;
  letter-spacing: .01em;
}
.hero-reassure::before { content: "→ "; color: var(--accent); }

/* Highlights card */
.hilite {
  border: 1px solid var(--rule);
  border-radius: 16px;
  background: var(--paper);
  padding: 28px;
  box-shadow: 0 1px 2px rgba(40,30,15,.04), 0 16px 40px -12px rgba(40,30,15,.12);
}
.hi-top { display: flex; gap: 16px; align-items: center; }
.hi-pic {
  width: 64px; height: 64px; flex-shrink: 0;
  border-radius: 50%;
  border: 1px solid var(--rule);
  background: repeating-linear-gradient(135deg, var(--paper-2) 0 6px, transparent 6px 12px), var(--paper-3);
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 9px; color: var(--ink-faint);
}
.hi-name { font-size: 19px; font-weight: 600; letter-spacing: -.01em; }
.hi-tag { font-size: 15px; font-style: italic; color: var(--ink-soft); margin-top: 3px; line-height: 1.35; }
.hi-stats {
  list-style: none;
  margin-top: 22px;
  padding-top: 20px;
  border-top: 1px solid var(--rule);
  display: flex; flex-direction: column; gap: 15px;
}
.hi-stats li {
  display: grid;
  grid-template-columns: 16px 1fr;
  gap: 11px;
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.45;
  color: var(--ink-soft);
}
.hi-stats .s { color: var(--accent); }

/* Logo strip */
.logos {
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  padding: 30px 0;
}
.cap {
  text-align: center;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-bottom: 22px;
}
.marquee {
  position: relative;
  overflow: hidden;
  display: flex; /* tracks sit side-by-side in one row */
}
.marquee::before,
.marquee::after {
  content: "";
  position: absolute;
  top: 0; bottom: 0; width: 84px; z-index: 2; pointer-events: none;
}
.marquee::before { left: 0; background: linear-gradient(90deg, var(--paper), transparent); }
.marquee::after  { right: 0; background: linear-gradient(270deg, var(--paper), transparent); }
.track {
  display: flex;
  align-items: center;
  gap: clamp(32px, 5vw, 64px);
  flex-shrink: 0;
  min-width: 100%;
  animation: marquee-scroll 28s linear infinite;
}
@keyframes marquee-scroll { to { transform: translateX(-100%); } }
@media (prefers-reduced-motion: reduce) {
  .marquee { display: block; }
  .track { animation: none; width: 100%; min-width: 0; justify-content: space-around; }
  .track[aria-hidden="true"] { display: none; }
}
.logo {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--serif);
  font-weight: 600;
  font-size: 16px;
  letter-spacing: -.01em;
  color: var(--ink);
  white-space: nowrap;
}
@media (min-width: 680px) {
  .logo { font-size: 21px; gap: 9px; }
}
.mk { width: 11px; height: 11px; flex-shrink: 0; border: 1.5px solid var(--accent); display: inline-block; }
.mk-circle { border-radius: 50%; }
.mk-diamond { transform: rotate(45deg); background: var(--accent); border: none; }
.mk-dashed { border-radius: 50%; border-style: dashed; }
.mk-square { border-radius: 3px; background: var(--accent); border: none; }
.l-cw { font-family: var(--mono); font-weight: 500; font-size: 16px; color: var(--ink-soft); letter-spacing: 0; }

/* Real logo images */
.logo-img {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}
.logo-asset {
  height: 22px;
  width: auto;
  object-fit: contain;
  filter: grayscale(1) brightness(0.25);
  opacity: 0.85;
}
/* Light-background logos — multiply blends white into paper, grayscale tints to ink */
.logo-asset-light-bg {
  filter: grayscale(1) contrast(1.2);
  mix-blend-mode: multiply;
  opacity: 0.82;
  height: 34px;
}
@media (min-width: 680px) {
  .logo-asset { height: 28px; }
  .logo-asset-light-bg { height: 40px; }
}

/* Band sections */
.band { padding: clamp(52px, 7vw, 84px) 0; }
.band + .band { border-top: 1px solid var(--rule); }
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 14px;
  flex-wrap: wrap;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--ink);
  margin-bottom: clamp(28px, 3.5vw, 44px);
}
.section-head h2 {
  font-size: clamp(28px, 4vw, 46px);
  font-weight: 500;
  letter-spacing: -.015em;
  line-height: 1.04;
  text-wrap: balance;
}
.section-head a:hover { color: var(--accent) !important; }

/* Articles grid */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 12px;
  overflow: hidden;
}
@media (max-width: 760px) { .articles-grid { grid-template-columns: 1fr; } }
.article {
  background: var(--paper);
  padding: 26px;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: var(--ink);
  transition: background .15s;
}
.article:hover { background: var(--paper-2); }
.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.cat { color: var(--accent); }
.min { color: var(--ink-faint); }
.article h3 { font-size: 22px; font-weight: 500; line-height: 1.18; letter-spacing: -.01em; }
.article > p { font-size: 15px; line-height: 1.5; color: var(--ink-soft); margin-top: 12px; }
.read { font-family: var(--mono); font-size: 11px; letter-spacing: .05em; color: var(--ink); margin-top: 22px; }

/* About */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(32px, 5vw, 56px);
  align-items: start;
}
@media (max-width: 860px) { .about-grid { grid-template-columns: 1fr; gap: 24px; } }
.about-grid h2 {
  font-size: clamp(30px, 4.2vw, 48px);
  font-weight: 500;
  line-height: 1.04;
  letter-spacing: -.015em;
  text-wrap: balance;
}
.about-body p { font-size: 17.5px; line-height: 1.55; color: var(--ink-soft); margin-bottom: 18px; text-wrap: pretty; }
.about-body p:last-child { margin-bottom: 0; }
.about-body strong { color: var(--ink); font-weight: 600; }
</style>
