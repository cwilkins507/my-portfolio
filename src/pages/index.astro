---
import Layout from '../layouts/Layout.astro';
import StartHere from '../components/StartHere';

const articleModules = import.meta.glob('../articles/*.md', { eager: true });
const articles = Object.entries(articleModules).map(([file, article]) => ({
  slug: file.split('/').pop().replace('.md', ''),
  ...article.frontmatter,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const CATEGORIES = {
  'AI & Agents': ['AI', 'LLM Tools', 'CLI Agents', 'MCP', 'Workflow Automation', 'Prompt Engineering', 'AI Coding Assistant', 'AI Tools', 'Agentic Development', 'Context Engineering'],
  'Cloud & DevOps': ['AWS', 'Terraform', 'Infrastructure as Code', 'DevOps', 'Serverless', 'Azure', 'GCP'],
  'Architecture': ['Software Architecture', 'System Design', 'Microservices', 'Distributed Systems'],
  'Engineering': ['Software Engineering', 'Best Practices', 'Low-code', 'Database Optimization']
};

const getCategoryForArticle = (tags) => {
  if (!tags || tags.length === 0) return 'Engineering';
  for (const [category, categoryTags] of Object.entries(CATEGORIES)) {
    for (const tag of tags) {
      if (categoryTags.some(catTag => catTag.toLowerCase() === tag.toLowerCase())) {
        return category;
      }
    }
  }
  return 'Engineering';
};

const START_HERE_SLUGS = [
  {
    slug: 'context-engineering-ai-coding-tools',
    blurb: "Why AI tools produce bad output isn't the model, it's the context. Convention files are how you turn AI coding tools from novelty into compounding productivity.",
  },
  {
    slug: 'llm-gateway-architecture',
    blurb: "When you need a gateway, when you don't, and how to avoid lock-in. The routing layer most teams skip until it's too late.",
  },
  {
    slug: 'claude-code-productivity-paradox',
    blurb: "Individual metrics are up. Organizational metrics are flat. The gap between 'developer goes faster' and 'team ships more' is where most AI pilots die.",
  },
];

const startHereArticles = START_HERE_SLUGS
  .map(entry => {
    const article = articles.find(a => a.slug === entry.slug);
    if (!article) return null;
    return {
      ...article,
      blurb: entry.blurb,
      category: getCategoryForArticle(article.tags),
    };
  })
  .filter(Boolean);

const latestArticles = articles.slice(0, 5);

const totalArticles = articles.length;

const credibilitySignals = [
  `12 years at Ford & enterprise financial data`,
  '$5M saved via connected-vehicle automation',
  `${totalArticles} published articles`,
  'Lead Engineer, currently shipping production AI',
];

const formatDate = (dateString) => {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC'
  });
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Collin Wilkins',
  url: 'https://collinwilkins.com',
  description:
    'Practitioner notes on AI coding tools, convention files, and automation architecture from a Lead Software Engineer with 12 years across Ford Motor Company and enterprise financial data.',
  author: {
    '@type': 'Person',
    name: 'Collin Wilkins',
    url: 'https://collinwilkins.com/about',
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Collin Wilkins',
  jobTitle: 'Lead Software Engineer',
  description:
    'Lead Software Engineer with 12 years across Ford Motor Company and Morningstar. Writes about AI coding tools, convention files, automation architecture, and production software.',
  url: 'https://collinwilkins.com',
  image: 'https://collinwilkins.com/images/profile_photo.png',
  sameAs: [
    'https://www.linkedin.com/in/collin-wilkins-1020215a/',
    'https://github.com/cwilkins507',
    'https://www.upwork.com/freelancers/~014ffbc17b83da9407',
  ],
  knowsAbout: [
    'Python',
    'AWS',
    'AI Automation',
    'Serverless Architecture',
    'Software Engineering',
    'IoT',
    'AI Agents',
    'Claude Code',
    'AGENTS.md',
    'CLAUDE.md',
    'Convention Files',
    'LLM Gateway Architecture',
    'Event-Driven Architecture',
    'Context Engineering',
  ],
  alumniOf: [
    {
      '@type': 'Organization',
      name: 'Ford Motor Company',
    },
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Morningstar',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who is Collin Wilkins?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Collin Wilkins is a Lead Software Engineer at Morningstar with 12 years across engineering, finance, pricing, sales, and operations. He previously worked on Ford connected vehicle systems, including telemetry and automation work tied to approximately $5 million in annual savings.',
      },
    },
    {
      '@type': 'Question',
      name: 'What topics does collinwilkins.com cover?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The site covers AI coding tool adoption, context engineering, convention files, LLM gateway architecture, AWS Lambda automation patterns, Python automation, system design, and production-grade infrastructure from a practitioner perspective.',
      },
    },
  ],
};
---

<Layout
  title="Collin Wilkins | AI Tools, Automation Architecture, and Convention Files"
  description="Practitioner notes on AI coding tools, convention files, and automation architecture. Lead Software Engineer with 12 years across Ford Motor Company and enterprise financial data."
  schema={[websiteSchema, personSchema, faqSchema]}
>
  <div class="min-h-screen bg-[var(--color-bg)] tracking-normal">

    <!-- ============ HERO ============ -->
    <section class="relative isolate overflow-hidden border-b border-[var(--color-border)] pt-24 pb-16 md:pt-32 md:pb-20">
      <div class="home-grid pointer-events-none absolute inset-0 opacity-80" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -left-36 top-20 h-80 w-80 rounded-full bg-[var(--color-blur-primary)] blur-3xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute right-[-12rem] top-12 h-[28rem] w-[28rem] rounded-full bg-[var(--color-blur-secondary)] blur-3xl" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-6xl px-6 md:px-8">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start">
          <div class="min-w-0 flex items-start gap-7 md:gap-9">
            <div class="hidden md:block flex-none w-px self-stretch bg-gradient-to-b from-[var(--color-accent)] via-[var(--color-accent-border)] to-transparent mt-1" aria-hidden="true"></div>
            <div class="flex-1 min-w-0">
              <p class="ink-label mb-5 font-mono text-[11px] text-[var(--color-accent)]">
                Collin Wilkins / AI systems / practical automation
              </p>
              <h1 class="max-w-[640px] font-serif text-4xl font-bold leading-[1.08] tracking-tight text-[var(--color-text-primary)] sm:text-5xl md:text-[3.5rem]">
                Practitioner notes on AI tools, convention files, and automation architecture.
              </h1>
              <p class="mt-7 max-w-[560px] text-lg leading-relaxed text-[var(--color-text-secondary)] md:text-xl">
                Lead Software Engineer with 12 years across Ford Motor Company and enterprise financial data. I write about what actually works when engineering teams adopt AI coding tools, and what breaks when they don't set up the context layer first.
              </p>

              <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <a
                  href="#start-here"
                  class="inline-flex min-h-12 items-center justify-center rounded-full bg-[var(--color-accent)] px-6 text-sm font-bold text-white shadow-[0_16px_50px_rgba(201,169,110,0.22)] transition-all hover:-translate-y-0.5 hover:bg-[var(--color-accent-hover)]"
                >
                  Start here <span class="ml-2" aria-hidden="true">&rarr;</span>
                </a>
                <a
                  href="/resources"
                  class="inline-flex min-h-12 items-center justify-center rounded-full border border-[var(--color-border-hover)] bg-[var(--color-surface-glass)] px-6 text-sm font-bold text-[var(--color-text-primary)] backdrop-blur transition-all hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                >
                  Browse resources
                </a>
                <a
                  href="#newsletter"
                  class="inline-flex min-h-12 items-center justify-center rounded-full border border-transparent px-5 text-sm font-bold text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]"
                >
                  Subscribe to the newsletter
                </a>
              </div>
            </div>
          </div>

          <aside class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 backdrop-blur-xl" aria-label="About the author">
            <div class="flex items-center gap-4 mb-5">
              <img
                src="/images/profile_photo.png"
                alt="Collin Wilkins"
                class="h-16 w-16 flex-none rounded-full border border-[var(--color-border-hover)] object-cover"
              />
              <div>
                <p class="font-sans text-[1.1rem] font-semibold text-[var(--color-text-primary)]">
                  Collin Wilkins
                </p>
                <p class="text-[0.95rem] text-[var(--color-text-secondary)]">
                  Business operator turned software engineer.
                </p>
              </div>
            </div>

            <ul class="space-y-3.5">
              {credibilitySignals.map(signal => (
                <li class="flex items-start gap-2.5 font-mono text-[0.82rem] leading-[1.45] text-[var(--color-text-muted)]">
                  <span class="text-[var(--color-accent)] text-xs mt-0.5 flex-shrink-0" aria-hidden="true">/</span>
                  {signal}
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ START HERE ============ -->
    <section id="start-here" class="mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
      <div class="flex items-baseline justify-between border-b border-[var(--color-border)] pb-5 mb-12">
        <h2 class="font-serif text-2xl font-bold tracking-tight text-[var(--color-text-primary)] md:text-[2rem]">
          Start Here
        </h2>
        <a href="/articles" class="font-mono text-[0.82rem] uppercase tracking-[0.05em] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          View all {totalArticles} articles &rarr;
        </a>
      </div>

      <StartHere articles={startHereArticles} client:load />
    </section>

    <!-- ============ LATEST ARTICLES ============ -->
    <section class="mx-auto max-w-6xl px-6 pb-20 md:px-8 md:pb-24">
      <div class="flex items-baseline justify-between border-b border-[var(--color-border)] pb-5 mb-12">
        <h2 class="font-serif text-2xl font-bold tracking-tight text-[var(--color-text-primary)] md:text-[2rem]">
          Latest
        </h2>
        <a href="/articles" class="font-mono text-[0.82rem] uppercase tracking-[0.05em] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          Browse archive &rarr;
        </a>
      </div>

      <div class="flex flex-col gap-14">
        {latestArticles.map(article => (
          <a
            href={`/articles/${article.slug}`}
            class="group grid gap-5 items-center md:grid-cols-[260px_1fr] md:gap-12"
          >
            <div class="aspect-video rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden transition-all duration-300 group-hover:border-[var(--color-border-hover)] flex items-center justify-center relative">
              {article.image ? (
                <img
                  src={article.image}
                  alt={article.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <span class="font-mono text-[9px] uppercase tracking-[0.1em] text-[var(--color-text-faint)]">
                  Hero image
                </span>
              )}
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,169,110,0.04),transparent_70%)]" aria-hidden="true"></div>
            </div>

            <div>
              <div class="flex items-center gap-4 font-mono text-[0.82rem] text-[var(--color-text-muted)] mb-3.5">
                <span class="text-[var(--color-accent)] bg-[var(--color-accent-muted)] px-2.5 py-0.5 rounded-full text-[0.72rem] uppercase tracking-[0.05em]">
                  {getCategoryForArticle(article.tags)}
                </span>
                <span>{formatDate(article.date)}</span>
              </div>
              <h3 class="font-serif text-[1.75rem] font-bold leading-[1.2] tracking-tight text-[var(--color-text-primary)] mb-3 transition-colors group-hover:text-[var(--color-accent)]">
                {article.title}
              </h3>
              <p class="text-base leading-relaxed text-[var(--color-text-secondary)] max-w-[560px]">
                {article.excerpt}
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ============ NEWSLETTER CTA ============ -->
    <section id="newsletter" class="border-t border-[var(--color-border)] px-6 py-16 md:px-8 md:py-24">
      <div class="mx-auto max-w-[480px] text-center">
        <div class="relative rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-10 md:p-12 backdrop-blur-xl overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent" aria-hidden="true"></div>

          <h2 class="font-serif text-2xl font-bold text-[var(--color-text-primary)] mb-3 md:text-[1.8rem]">
            Notes from production.
          </h2>
          <p class="text-[1.05rem] text-[var(--color-text-secondary)] leading-relaxed mb-8">
            Every other week: working playbooks on AI coding tools, convention files, and automation architecture.
          </p>

          <form
            action="https://buttondown.com/api/emails/embed-subscribe/collinwilkins"
            method="post"
            target="popupwindow"
            class="flex flex-col sm:flex-row gap-3 w-full"
          >
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="flex-1 min-h-12 px-5 py-3 text-[0.95rem] bg-[rgba(0,0,0,0.3)] border border-[var(--color-border)] rounded-full text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[rgba(255,255,255,0.25)] focus:bg-[rgba(0,0,0,0.5)] transition-all font-sans"
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center min-h-12 px-7 rounded-full bg-[var(--color-accent)] text-white font-semibold text-[0.95rem] transition-all hover:bg-[var(--color-accent-hover)] hover:-translate-y-0.5 shadow-[0_16px_50px_rgba(201,169,110,0.18)]"
            >
              Subscribe
            </button>
          </form>

          <p class="text-xs text-[var(--color-text-muted)] mt-4">
            No spam. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </section>

  </div>
</Layout>
