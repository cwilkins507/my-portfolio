---
import Layout from '../layouts/Layout.astro';
import ArticleList from '../components/Articles';
import AnimatedHero from '../components/AnimatedHero';
import GlowDivider from '../components/GlowDivider';
import NavigationWrapper from '../components/NavigationWrapper';

const articlesRaw = await Astro.glob('../articles/*.md');
const articles = articlesRaw.map(article => ({
  slug: article.file.split('/').pop().replace('.md', ''),
  ...article.frontmatter,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Featured articles (curated — Writer Site Refresh, 2026-04-10)
const FEATURED_SLUGS = [
  'context-engineering-ai-coding-tools',
  'llm-gateway-architecture',
  'claude-code-productivity-paradox',
];
const featuredArticles = FEATURED_SLUGS
  .map(slug => articles.find(a => a.slug === slug))
  .filter(Boolean);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Collin Wilkins",
  "url": "https://collinwilkins.com",
  "description": "Technical articles on Python automation, AWS serverless architecture, AI integration, and building systems that deliver measurable business value.",
  "author": {
    "@type": "Person",
    "name": "Collin Wilkins",
    "url": "https://collinwilkins.com/about"
  }
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Collin Wilkins",
  "jobTitle": "Lead Software Engineer",
  "description": "Lead Engineer with 12 years of enterprise engineering experience across Ford Motor Company and Morningstar. Writes about AI coding tools, convention files, and automation architecture.",
  "url": "https://collinwilkins.com",
  "image": "https://collinwilkins.com/images/profile_photo.png",
  "sameAs": [
    "https://www.linkedin.com/in/collin-wilkins-1020215a/",
    "https://github.com/cwilkins507",
    "https://www.upwork.com/freelancers/~014ffbc17b83da9407"
  ],
  "knowsAbout": [
    "Python",
    "AWS",
    "AI Automation",
    "Serverless Architecture",
    "Software Engineering",
    "IoT",
    "AI Agents",
    "Claude Code",
    "AGENTS.md",
    "CLAUDE.md",
    "Convention Files",
    "LLM Gateway Architecture"
  ],
  "alumniOf": [
    {
      "@type": "Organization",
      "name": "Ford Motor Company"
    }
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Morningstar"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is Collin Wilkins?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Collin Wilkins is a Lead Software Engineer at Morningstar with 12 years of enterprise engineering experience. He previously built IoT telemetry and automation systems at Ford Motor Company that cut approximately $5 million in annual operational costs, including the platform behind the 2024 F-150 theft recovery feature. He writes practitioner notes on AI coding tools, convention files, LLM gateway architecture, and production automation."
      }
    },
    {
      "@type": "Question",
      "name": "What are convention files in the context of AI coding tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Convention files (CLAUDE.md, AGENTS.md, .cursorrules) are project context files that load automatically when an AI coding agent starts a session. They encode project structure, build and test commands, naming conventions, constraints the agent should never violate, and the reasoning behind those constraints. Well-written convention files are the difference between AI tools producing inconsistent output and compounding productivity over time, because they solve the real problem: context, not model quality."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between CLAUDE.md and AGENTS.md?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CLAUDE.md is specific to Claude Code and loads automatically at the start of every session with project context. AGENTS.md is an emerging cross-tool convention — a single file that multiple coding agents (Claude Code, Codex, Cursor, and others) can read, reducing the need to maintain separate rule files per tool. Both serve the same purpose: encoding what the agent needs to know about the project before it starts working."
      }
    },
    {
      "@type": "Question",
      "name": "What topics does collinwilkins.com cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI coding tool adoption (Claude Code, Cursor, Copilot), convention files and context engineering (CLAUDE.md, AGENTS.md), LLM gateway architecture, AWS Lambda automation patterns, Python automation, system design, and production-grade infrastructure. The focus is on practitioner patterns from real enterprise engineering work — specific, battle-tested, and statistics-rich rather than generic AI-transformation framing."
      }
    }
  ]
};
---

<Layout
  title="Collin Wilkins | Lead Software Engineer"
  description="Practitioner notes on AI coding tools, convention files, and automation architecture. 12 years of enterprise engineering across Ford Motor Company and Morningstar."
  schema={[websiteSchema, personSchema, faqSchema]}
>
	<!-- Override Navigation to include SearchOverlay -->
	<NavigationWrapper articles={articles} client:load />

	<!-- 1. Hero Section -->
	<AnimatedHero
		headline="Practitioner Notes on AI Coding Tools, Convention Files, and Automation Architecture"
		subheadline="12 years of enterprise engineering — previously IoT telemetry and $5M in automation savings at Ford Motor Company, now Lead Engineer at Morningstar. I write about AI coding tools, convention files, and automation architecture for engineering teams."
		availabilityBadge="Currently taking 2–3 clients"
		emphasizeWords={['AI', 'Coding', 'Convention', 'Automation']}
		ctas={[
			{ href: '#articles', text: 'Read the writing', variant: 'primary' },
			{ href: '/services', text: 'Work with me', variant: 'secondary' }
		]}
	/>

	<!-- 2. Glow Divider -->
	<GlowDivider />

	<!-- 3. Featured Articles (Start Here) -->
	<section class="py-12 md:py-20 max-w-5xl mx-auto px-6 md:px-8">
		<div class="flex items-baseline gap-4 mb-8">
			<h2 class="text-lg font-serif font-bold text-[var(--color-text-primary)]">Start Here</h2>
			<span class="text-xs text-[var(--color-text-faint)] uppercase tracking-widest font-mono">3 articles</span>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
			{/* First card: featured slot — spans full height left column */}
			{featuredArticles[0] && (
				<a
					href={`/articles/${featuredArticles[0].slug}`}
					class="group flex flex-col rounded-xl p-7 md:p-8 border border-[var(--color-accent-border)] bg-[var(--color-accent-muted)] hover:bg-[var(--color-surface-hover)] hover:border-[var(--color-accent)] hover:-translate-y-0.5 will-change-transform transition-all duration-300 md:row-span-2 relative overflow-hidden"
				>
					<div class="pointer-events-none absolute -right-8 -top-8 w-40 h-40 rounded-full opacity-60" style="background: radial-gradient(ellipse, rgba(201,169,110,0.12) 0%, transparent 70%);" aria-hidden="true"></div>
					<span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4 block">Featured</span>
					<h3 class="text-2xl md:text-3xl font-serif font-bold text-[var(--color-text-primary)] mb-4 leading-[1.2] group-hover:text-[var(--color-accent)] transition-colors flex-grow">
						{featuredArticles[0].title}
					</h3>
					<p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-8">
						{featuredArticles[0].excerpt}
					</p>
					<span class="text-[var(--color-accent)] text-sm font-semibold inline-flex items-center gap-2 mt-auto">
						Read article <span aria-hidden="true">&rarr;</span>
					</span>
				</a>
			)}
			{/* Cards 2 & 3: secondary slots — stack on the right */}
			{featuredArticles.slice(1).map(article => (
				<a
					href={`/articles/${article.slug}`}
					class="group flex flex-col rounded-xl p-6 border border-[var(--color-border)] bg-[var(--color-surface)] hover:bg-[var(--color-surface-hover)] hover:border-[var(--color-border-hover)] hover:-translate-y-0.5 will-change-transform transition-all duration-300"
				>
					<h3 class="text-lg font-serif font-bold text-[var(--color-text-primary)] mb-2 leading-snug group-hover:text-[var(--color-accent)] transition-colors">
						{article.title}
					</h3>
					<p class="text-[var(--color-text-secondary)] text-sm leading-relaxed flex-grow mb-4">
						{article.excerpt}
					</p>
					<span class="text-[var(--color-accent)] text-sm font-semibold inline-flex items-center gap-2">
						Read article <span aria-hidden="true">&rarr;</span>
					</span>
				</a>
			))}
		</div>
	</section>

	<!-- 4. Newsletter capture — between curated articles and full list -->
	<section class="py-14 max-w-7xl mx-auto px-6 md:px-8">
		<div class="flex flex-col lg:flex-row lg:items-center gap-8 p-8 md:p-10 lg:p-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] relative overflow-hidden">
			<!-- Subtle gold blur -->
			<div class="pointer-events-none absolute right-0 top-0 w-64 h-full rounded-r-2xl" style="background: radial-gradient(ellipse at top right, rgba(201,169,110,0.06) 0%, transparent 70%);" aria-hidden="true"></div>
			<div class="flex-1 relative z-[1]">
				<p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3">Newsletter · Every other week</p>
				<h3 class="text-2xl font-serif font-bold text-[var(--color-text-primary)] mb-2">Notes from production.</h3>
				<p class="text-base text-[var(--color-text-secondary)] leading-relaxed">Working playbooks and field notes for learning by doing. AI coding, convention files, automation architecture, and the production details that decide whether the work survives past the demo.</p>
			</div>
			<form
				action="https://buttondown.com/api/emails/embed-subscribe/collinwilkins"
				method="post"
				target="popupwindow"
				class="flex flex-col sm:flex-row gap-3 flex-none w-full lg:w-[42rem] relative z-[1]"
			>
				<input
					type="email"
					name="email"
					placeholder="your@email.com"
					required
					class="flex-1 min-h-14 px-5 py-4 text-base bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text-primary)] placeholder-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition"
				/>
				<button
					type="submit"
					class="min-h-14 px-7 py-4 text-base font-semibold rounded-lg bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)] transition-colors whitespace-nowrap"
				>
					Subscribe
				</button>
			</form>
		</div>
	</section>

	<!-- 7. All Articles Section -->
	<section id="articles" class="py-16">
		<ArticleList articles={articles} client:load />
		<!-- Server-rendered article links for SEO crawlers -->
		<noscript>
			<div class="container mx-auto px-4 py-16">
				<h2 class="text-2xl font-serif font-bold text-[var(--color-text-primary)] mb-8">All Articles</h2>
				<ul class="space-y-4">
					{articles.map(article => (
						<li>
							<a href={`/articles/${article.slug}`} class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] text-lg">
								{article.title}
							</a>
							<p class="text-[var(--color-text-muted)] text-sm">{article.date}</p>
						</li>
					))}
				</ul>
			</div>
		</noscript>
	</section>

</Layout>
