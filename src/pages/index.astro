---
import Layout from '../layouts/Layout.astro';

const articleModules = import.meta.glob('../articles/*.md', { eager: true });
const articles = Object.entries(articleModules).map(([file, article]) => ({
  slug: file.split('/').pop().replace('.md', ''),
  ...article.frontmatter,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const FEATURED_SLUGS = [
  'context-engineering-ai-coding-tools',
  'llm-gateway-architecture',
  'claude-code-productivity-paradox',
];

const featuredArticles = FEATURED_SLUGS
  .map(slug => articles.find(article => article.slug === slug))
  .filter(Boolean);

const workAreas = [
  {
    title: 'AI tools inside engineering teams',
    description:
      'I help teams get Claude Code, Cursor, Copilot, and Codex out of side-project mode and into repo conventions, review habits, and repeatable workflows.',
    signal: 'Claude Code, Cursor, Copilot, Codex',
  },
  {
    title: 'Automation and internal systems',
    description:
      "If a team is still clicking through Postman, copying CSVs, or babysitting runs by hand, there's probably a better system hiding in there. Python, APIs, Lambda, queues, n8n when it fits. Boring on purpose.",
    signal: 'Python, APIs, Lambda, queues, integrations',
  },
  {
    title: 'Architecture when the problem is still fuzzy',
    description:
      "Some problems don't need a giant platform. They need someone to map the workflow, find the expensive part, build the right slice, and leave the decision trail somewhere better than Slack.",
    signal: 'Architecture, implementation, decision support',
  },
];

const selectedWork = [
  {
    company: 'Ford Motor Company',
    title: 'Eliminating a 30-day manual audit process',
    metric: '$5M',
    metricLabel: 'annual savings',
    summary:
      'I led the architecture for a telemetry platform that checked dealership inventory with connected-vehicle signals instead of slow physical audits. Fewer lot visits, less delay, about $5M in annual savings.',
    tags: ['Kafka', 'Pub/Sub', 'Azure IoT Hub'],
  },
  {
    company: 'Morningstar',
    title: 'Cutting 20% of weekly engineering bandwidth',
    metric: '90%',
    metricLabel: 'fewer daily runs',
    summary:
      'I moved daily compliance runs out of Postman and into an event-driven workflow with load-aware scheduling, database diffing, SQS, and short-lived Fargate tasks. Less babysitting. More actual engineering time.',
    tags: ['AWS SQS', 'Fargate', 'Event-driven systems'],
  },
  {
    company: 'Ford Motor Company',
    title: "Protecting America's most stolen vehicle",
    metric: '2024',
    metricLabel: 'production launch',
    summary:
      "I worked on the telemetry behind F-150 theft recovery, where you can't just spam location data and call it done. Recovery speed had to sit with privacy, battery, and cost.",
    tags: ['Zero Trust', 'Kafka', 'IoT telemetry'],
  },
];

const credibilitySignals = [
  'Lead Software Engineer at Morningstar',
  'Previously Ford connected vehicle systems, pricing, and field work',
  '12 years across engineering, pricing, sales, and operations',
  'Case studies covering $5M savings, 450k+ vehicles, and 600k+ daily events',
];

const operatingNotes = [
  {
    label: 'Best fit',
    value: 'Messy workflow, real stakes',
  },
  {
    label: 'Mode',
    value: 'Architecture plus implementation',
  },
  {
    label: 'Bias',
    value: 'Ship the useful slice first',
  },
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Collin Wilkins',
  url: 'https://collinwilkins.com',
  description:
    'Portfolio for Collin Wilkins, a Lead Software Engineer focused on AI tools, automation, internal systems, and software that has to work in production.',
  author: {
    '@type': 'Person',
    name: 'Collin Wilkins',
    url: 'https://collinwilkins.com/about',
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Collin Wilkins',
  jobTitle: 'Lead Software Engineer',
  description:
    'Lead Software Engineer with 12 years across Ford Motor Company and Morningstar. Focused on AI tools, automation, internal systems, and production software.',
  url: 'https://collinwilkins.com',
  image: 'https://collinwilkins.com/images/profile_photo.png',
  sameAs: [
    'https://www.linkedin.com/in/collin-wilkins-1020215a/',
    'https://github.com/cwilkins507',
    'https://www.upwork.com/freelancers/~014ffbc17b83da9407',
  ],
  knowsAbout: [
    'Python',
    'AWS',
    'AI Automation',
    'Serverless Architecture',
    'Software Engineering',
    'IoT',
    'AI Agents',
    'Claude Code',
    'AGENTS.md',
    'CLAUDE.md',
    'Convention Files',
    'LLM Gateway Architecture',
    'Event-Driven Architecture',
  ],
  alumniOf: [
    {
      '@type': 'Organization',
      name: 'Ford Motor Company',
    },
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Morningstar',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who is Collin Wilkins?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Collin Wilkins is a Lead Software Engineer at Morningstar with 12 years across engineering, finance, pricing, sales, and operations. He previously worked on Ford connected vehicle systems, including telemetry and automation work tied to approximately $5 million in annual savings.',
      },
    },
    {
      '@type': 'Question',
      name: 'What kind of consulting work does Collin Wilkins take on?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Collin takes on limited independent work for teams dealing with AI tool rollout, automation architecture, internal systems, and hands-on Python or AWS implementation.',
      },
    },
    {
      '@type': 'Question',
      name: 'What topics does collinwilkins.com cover?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The site covers AI coding tool adoption, context engineering, convention files, LLM gateway architecture, AWS Lambda automation patterns, Python automation, system design, and production-grade infrastructure from a practitioner perspective.',
      },
    },
  ],
};
---

<Layout
  title="Collin Wilkins | AI Tools, Automation, and Internal Systems"
  description="Lead Software Engineer at Morningstar, previously Ford. I work on AI tools, automation, and production software for teams dealing with expensive process problems."
  schema={[websiteSchema, personSchema, faqSchema]}
>
  <div class="min-h-screen bg-[var(--color-bg)] tracking-normal">
    <section class="relative isolate overflow-hidden border-b border-[var(--color-border)] pt-24 pb-16 md:pt-32 md:pb-20">
      <div class="home-grid pointer-events-none absolute inset-0 opacity-80" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -left-36 top-20 h-80 w-80 rounded-full bg-[var(--color-blur-primary)] blur-3xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute right-[-12rem] top-12 h-[28rem] w-[28rem] rounded-full bg-[var(--color-blur-secondary)] blur-3xl" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-6xl px-6 md:px-8">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_390px] lg:items-center">
          <div class="min-w-0 flex items-start gap-7 md:gap-9">
            <div class="hidden md:block flex-none w-px self-stretch bg-gradient-to-b from-[var(--color-accent)] via-[var(--color-accent-border)] to-transparent mt-1" aria-hidden="true"></div>
            <div class="flex-1 min-w-0">
            <p class="ink-label mb-5 font-mono text-[11px] text-[var(--color-accent)]">
              Collin Wilkins / AI systems / practical automation
            </p>
            <h1 class="max-w-3xl font-serif text-4xl font-bold leading-[1.05] tracking-tight text-[var(--color-text-primary)] sm:text-5xl md:text-6xl">
              I fix expensive software problems everyone works around.
            </h1>
            <p class="mt-7 max-w-3xl text-lg leading-relaxed text-[var(--color-text-secondary)] md:text-xl">
              Lead Software Engineer at Morningstar, previously Ford. I'm useful when the problem is part code, part process, and part organizational scar tissue: AI tooling getting weird, manual work that should have died years ago, or a system decision everyone keeps politely avoiding.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              <a
                href="/services#assessment"
                class="inline-flex min-h-12 items-center justify-center rounded-full bg-[var(--color-accent)] px-6 text-sm font-bold text-white shadow-[0_16px_50px_rgba(201,169,110,0.22)] transition-all hover:-translate-y-0.5 hover:bg-[var(--color-accent-hover)]"
              >
                Work with me <span class="ml-2" aria-hidden="true">&rarr;</span>
              </a>
              <a
                href="/case-studies"
                class="inline-flex min-h-12 items-center justify-center rounded-full border border-[var(--color-border-hover)] bg-[var(--color-surface-glass)] px-6 text-sm font-bold text-[var(--color-text-primary)] backdrop-blur transition-all hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
              >
                View selected work
              </a>
              <a
                href="/Collin-Wilkins-Resume.pdf"
                class="inline-flex min-h-12 items-center justify-center rounded-full border border-transparent px-5 text-sm font-bold text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]"
              >
                Download CV
              </a>
            </div>

            <div class="mt-9 grid gap-3 sm:grid-cols-3">
              {operatingNotes.map(note => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-glass)] p-4 backdrop-blur">
                  <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">{note.label}</p>
                  <p class="mt-2 text-sm font-semibold leading-snug text-[var(--color-text-primary)]">{note.value}</p>
                </div>
              ))}
            </div>
            </div>
          </div>

          <aside class="premium-card rounded-[2rem] p-5 md:p-6" aria-label="Current positioning">
            <div class="flex items-start gap-4">
              <img
                src="/images/profile_photo.png"
                alt="Collin Wilkins"
                class="h-16 w-16 flex-none rounded-2xl border border-[var(--color-border-hover)] object-cover shadow-lg"
              />
              <div class="min-w-0">
                <p class="font-serif text-2xl font-bold leading-tight text-[var(--color-text-primary)]">
                  Business operator turned software engineer.
                </p>
              </div>
            </div>

            <div class="mt-6 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Current lens</p>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-secondary)]">
                I learned to code because waiting on technical resources got expensive. That bias still shows up: find the cost, fix the workflow, and make the system honest enough for the team to run after handoff.
              </p>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
                <p class="font-mono text-3xl font-semibold text-[var(--color-accent)]">$5M</p>
                <p class="mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)]">annual savings from connected-vehicle audit automation</p>
              </div>
              <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
                <p class="font-mono text-3xl font-semibold text-[var(--color-signal-green)]">10h</p>
                <p class="mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)]">weekly engineering time reclaimed from manual compliance runs</p>
              </div>
            </div>

            <div class="mt-4 divide-y divide-[var(--color-border)] rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]">
              {credibilitySignals.map(signal => (
                <p class="px-4 py-3 text-sm leading-relaxed text-[var(--color-text-secondary)]">
                  <span class="mr-2 text-[var(--color-accent)]" aria-hidden="true">/</span>{signal}
                </p>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-[300px_minmax(0,1fr)] md:px-8 md:py-24">
      <div class="md:sticky md:top-28 md:self-start">
        <p class="ink-label font-mono text-[11px] text-[var(--color-accent)]">What I do</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-[var(--color-text-primary)] md:text-5xl">
          The useful work usually starts messy.
        </h2>
        <p class="mt-5 text-sm leading-relaxed text-[var(--color-text-secondary)]">
          The pattern is almost always the same: make the workflow legible, build the smallest durable system, and leave the team with context instead of mythology.
        </p>
      </div>

      <div class="grid gap-4">
        {workAreas.map((area, index) => (
          <article class="group grid gap-5 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-glass)] p-6 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-accent-border)] hover:bg-[var(--color-surface-hover)] md:grid-cols-[220px_minmax(0,1fr)] md:gap-8 md:p-7">
            <div>
              <span class="mb-5 inline-flex rounded-full border border-[var(--color-border)] px-3 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
                0{index + 1}
              </span>
              <h3 class="font-serif text-2xl font-bold leading-tight text-[var(--color-text-primary)] transition-colors group-hover:text-[var(--color-accent)]">
                {area.title}
              </h3>
              <p class="mt-3 font-mono text-xs uppercase leading-relaxed text-[var(--color-text-muted)]">
                {area.signal}
              </p>
            </div>
            <p class="text-base leading-relaxed text-[var(--color-text-secondary)] md:text-lg">
              {area.description}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="relative overflow-hidden border-y border-[var(--color-border)] bg-[var(--color-surface)]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-border)] to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute left-1/2 top-0 h-64 w-[38rem] -translate-x-1/2 rounded-full bg-[var(--color-blur-primary)] blur-3xl" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-24">
        <div class="mb-10 grid gap-6 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
          <div>
            <p class="ink-label font-mono text-[11px] text-[var(--color-accent)]">Selected work</p>
            <h2 class="mt-4 max-w-3xl font-serif text-3xl font-bold leading-tight text-[var(--color-text-primary)] md:text-5xl">
              A few examples from large systems where the constraints were not theoretical.
            </h2>
          </div>
          <a
            href="/case-studies"
            class="inline-flex min-h-11 items-center justify-center rounded-full border border-[var(--color-border-hover)] bg-[var(--color-surface-glass)] px-5 text-sm font-bold text-[var(--color-text-primary)] backdrop-blur transition-all hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            All case studies
          </a>
        </div>

        <div class="grid gap-5 lg:grid-cols-3">
          {selectedWork.map(work => (
            <article class="premium-card group flex min-h-full flex-col rounded-[1.75rem] p-6 transition-transform duration-300 hover:-translate-y-1 md:p-7">
              <div class="mb-7 flex items-start justify-between gap-5">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">{work.company}</p>
                  <p class="mt-2 text-xs font-semibold text-[var(--color-text-secondary)]">{work.metricLabel}</p>
                </div>
                <div class="text-right">
                  <p class="font-mono text-4xl font-semibold tracking-tight text-[var(--color-accent)]">{work.metric}</p>
                </div>
              </div>

              <h3 class="font-serif text-3xl font-bold leading-tight text-[var(--color-text-primary)] transition-colors group-hover:text-[var(--color-accent)]">
                {work.title}
              </h3>
              <p class="mt-5 flex-1 text-sm leading-relaxed text-[var(--color-text-secondary)]">
                {work.summary}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {work.tags.map(tag => (
                  <span class="rounded-full border border-[var(--color-border)] bg-[rgba(255,255,255,0.025)] px-3 py-1 text-xs font-medium text-[var(--color-text-secondary)]">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-[300px_minmax(0,1fr)] md:px-8 md:py-24">
      <div>
        <p class="ink-label font-mono text-[11px] text-[var(--color-accent)]">Writing</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-[var(--color-text-primary)] md:text-5xl">
          The writing is the longer version of how I think.
        </h2>
        <p class="mt-5 text-sm leading-relaxed text-[var(--color-text-secondary)]">
          It belongs here, just not as the front door. This is where I work through architecture decisions, AI tool behavior, and the places where production punishes vague thinking.
        </p>
      </div>

      <div class="grid gap-4">
        {featuredArticles.map((article, index) => (
          <a
            href={`/articles/${article.slug}`}
            class="group grid gap-5 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-glass)] p-6 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-accent-border)] hover:bg-[var(--color-surface-hover)] md:grid-cols-[48px_minmax(0,1fr)_auto] md:items-start"
          >
            <span class="font-mono text-xs text-[var(--color-text-muted)]">0{index + 1}</span>
            <div>
              <h3 class="font-serif text-2xl font-bold leading-tight text-[var(--color-text-primary)] transition-colors group-hover:text-[var(--color-accent)]">
                {article.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-secondary)]">{article.excerpt}</p>
            </div>
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[var(--color-border)] text-sm font-semibold text-[var(--color-accent)] transition-all group-hover:border-[var(--color-accent-border)] group-hover:bg-[var(--color-accent-muted)] md:justify-self-end">
              <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}

        <div class="pt-7">
          <a
            href="/articles"
            class="inline-flex min-h-11 items-center justify-center rounded-full border border-[var(--color-border-hover)] px-5 text-sm font-bold text-[var(--color-text-primary)] transition-all hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            Browse the full library
          </a>
        </div>
      </div>
    </section>

    <section class="border-t border-[var(--color-border)] px-6 py-16 md:px-8 md:py-24">
      <div class="premium-card mx-auto grid max-w-6xl gap-8 rounded-[2rem] p-7 md:grid-cols-[minmax(0,1fr)_auto] md:items-center md:p-10">
        <div>
          <p class="ink-label font-mono text-[11px] text-[var(--color-accent)]">Next step</p>
          <h2 class="mt-4 max-w-3xl font-serif text-3xl font-bold leading-tight text-[var(--color-text-primary)] md:text-5xl">
            Send the messy version. That's usually where the useful work starts.
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-[var(--color-text-secondary)]">
            Good fit: an AI rollout getting weird, a manual workflow nobody wants to keep touching, or a system decision that has been sitting around because every option has consequences.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
          <a
            href="/services#assessment"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[var(--color-accent)] px-6 text-sm font-bold text-white shadow-[0_16px_50px_rgba(201,169,110,0.22)] transition-all hover:-translate-y-0.5 hover:bg-[var(--color-accent-hover)]"
          >
            Start with a short call <span class="ml-2" aria-hidden="true">&rarr;</span>
          </a>
          <a
            href="/?modal=contact&service=automation-architecture"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-[var(--color-border-hover)] bg-[var(--color-surface)] px-6 text-sm font-bold text-[var(--color-text-primary)] transition-all hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            Send the context
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
