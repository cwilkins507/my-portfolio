---
import Layout from '../layouts/Layout.astro';
import CaseStudies from '../components/CaseStudies';

const caseStudiesSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": "Case Studies | Collin Wilkins",
	"description": "Engineering work portfolio: IoT telemetry at Ford Motor Company, event-driven compliance architecture at Morningstar, and privacy-first theft recovery for the 2024 F-150.",
	"url": "https://collinwilkins.com/case-studies",
	"author": {
		"@type": "Person",
		"name": "Collin Wilkins"
	}
};
---

<Layout
	title="Case Studies | Engineering Work Portfolio"
	description="Engineering work portfolio: IoT telemetry at Ford Motor Company, event-driven compliance architecture at Morningstar, and privacy-first theft recovery for the 2024 F-150."
	schema={caseStudiesSchema}
>
	<CaseStudies client:load />
	<noscript>
		<div class="container mx-auto px-4 py-16 max-w-4xl">
			<h1 class="text-4xl font-serif font-bold text-[var(--color-text-primary)] mb-6">Case Studies</h1>
			<p class="text-xl text-[var(--color-text-secondary)] mb-8">Engineering work from twelve years across enterprise orgs.</p>
			<h2 class="text-2xl font-serif font-bold text-[var(--color-text-primary)] mb-4">Eliminating a 30-Day Manual Process</h2>
			<p class="text-[var(--color-text-secondary)] mb-6">IoT telemetry platform at Ford Motor Company automating verification for 450,000+ vehicles, saving $5M annually.</p>
			<h2 class="text-2xl font-serif font-bold text-[var(--color-text-primary)] mb-4">Cutting 20% of Weekly Engineering Bandwidth</h2>
			<p class="text-[var(--color-text-secondary)] mb-6">Event-driven compliance architecture at Morningstar reducing daily runs by 90% and freeing 10 engineering hours weekly.</p>
			<h2 class="text-2xl font-serif font-bold text-[var(--color-text-primary)] mb-4">Protecting America's Most Stolen Vehicle</h2>
			<p class="text-[var(--color-text-secondary)] mb-6">Privacy-first telemetry system deployed in thousands of 2024 Ford F-150s for theft recovery.</p>
		</div>
	</noscript>
</Layout>
