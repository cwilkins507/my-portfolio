---
import Layout from '../../layouts/Layout.astro';

const chapters = [
  {
    id: 'chapter-1',
    number: '01',
    title: "Figuring Out If You're Ready",
    coreQuestion: 'Is the team ready for tooling, custom AI, or strategy work?',
    pillar: 'Readiness',
    readTime: '8 min',
    href: '/articles/how-to-know-if-your-business-is-ready-for-ai',
    takeaway: 'Do not buy AI maturity. Map the current operating level, then take the next step the team can actually absorb.',
    summary: [
      "Readiness is not yes or no. It is a spectrum: undefined workflows, AI-powered tools, custom AI, and AI strategy.",
      "The trap is spending real money on AI tooling while core engineering processes still live in tribal knowledge.",
      "A useful first pass asks who owns the rollout, what repeatable work exists, what metrics are available, and where the clearest bottleneck lives."
    ],
    links: [{ label: 'Read the full breakdown', href: '/articles/how-to-know-if-your-business-is-ready-for-ai' }]
  },
  {
    id: 'chapter-2',
    number: '02',
    title: 'Why Your AI Tools Produce Bad Output',
    coreQuestion: 'What context does the tool need before it can produce team-grade work?',
    pillar: 'Context',
    readTime: '10 min',
    href: '/articles/context-engineering-ai-coding-tools',
    takeaway: 'The model is rarely the whole problem. Teams get better output when context is versioned, reviewed, and maintained like production code.',
    summary: [
      "Context engineering means deliberately shaping what an AI coding tool knows before it starts working.",
      "That includes convention files such as CLAUDE.md and AGENTS.md, scoped work sessions, safety stops, memory files, and stack-specific rules.",
      "The teams that keep these files fresh turn individual prompting tricks into a repeatable engineering practice."
    ],
    links: [{ label: 'Read the full breakdown', href: '/articles/context-engineering-ai-coding-tools' }]
  },
  {
    id: 'chapter-3',
    number: '03',
    title: 'Which AI Tools Actually Matter',
    coreQuestion: 'How should teams choose models and route work without locking themselves in?',
    pillar: 'Tooling',
    readTime: '12 min',
    href: '/articles/ai-coding-model-wars-2026',
    takeaway: 'Tool selection is less about the highest benchmark and more about matching model cost, capability, latency, and compliance to the task.',
    summary: [
      "The model market keeps compressing: benchmark gaps shrink, price gaps remain large, and the best choice changes by task.",
      "Simple classification and formatting often belong on cheaper models. Heavy reasoning and review still justify frontier models.",
      "Once multiple services or providers are involved, a routing layer protects cost visibility, failover, and policy enforcement."
    ],
    links: [
      { label: 'Read the model market analysis', href: '/articles/ai-coding-model-wars-2026' },
      { label: 'Read the LLM gateway guide', href: '/articles/llm-gateway-architecture' }
    ]
  },
  {
    id: 'chapter-4',
    number: '04',
    title: 'The 5 Ways AI Pilots Die',
    coreQuestion: 'Why do individual productivity wins fail to move team delivery metrics?',
    pillar: 'Adoption',
    readTime: '9 min',
    href: '/articles/claude-code-productivity-paradox',
    takeaway: 'AI adoption fails when it stays personal. The work has to become shared practice: conventions, measurement, review changes, and skill transfer.',
    summary: [
      "Most pilots die from missing convention files, missing measurement, isolated power users, review bottlenecks, or unresolved senior skepticism.",
      "Self-reported speed is not enough. Teams need cycle time, quality, review load, and adoption telemetry.",
      "The fix is treating AI adoption as an operating change, not a pile of individual productivity subscriptions."
    ],
    links: [{ label: 'Read the full breakdown', href: '/articles/claude-code-productivity-paradox' }]
  },
  {
    id: 'chapter-5',
    number: '05',
    title: 'The Math That Makes the Decision',
    coreQuestion: 'When is AI automation worth the money and maintenance burden?',
    pillar: 'ROI',
    readTime: '8 min',
    href: '/articles/automation-cost-small-business',
    takeaway: 'Start with the smallest stable workflow where manual cost, automated cost, and payback period are visible.',
    summary: [
      "Most work falls into three tiers: low-cost SaaS features, custom agents/internal tools, or integrated AI systems.",
      "The basic payback math is manual monthly cost minus automated monthly cost, divided into the build cost.",
      "If payback is under six months and the process is stable, build. If the process keeps changing or payback stretches past a year, wait."
    ],
    links: [{ label: 'Read the full breakdown', href: '/articles/automation-cost-small-business' }]
  }
];

const resources = [
  {
    title: 'AI Readiness Diagnostic Worksheet',
    label: 'Download free',
    resource: 'ai-readiness-worksheet',
    format: 'xlsx',
    accessType: 'download_free',
    href: '/toolkit/AI-Readiness-Worksheet.xlsx',
    description: 'A 7-dimension scoring rubric for deciding whether the next move is process cleanup, AI-powered tools, custom AI, or strategy work.'
  },
  {
    title: 'CLAUDE.md Template',
    label: 'Download free',
    resource: 'claude-md-template',
    format: 'md',
    accessType: 'download_free',
    href: '/toolkit/CLAUDE.md',
    description: 'A Claude Code convention file starter with project context, workflow rules, safety stops, memory files, and verification expectations.'
  },
  {
    title: 'AGENTS.md Template',
    label: 'Download free',
    resource: 'agents-md-template',
    format: 'md',
    accessType: 'download_free',
    href: '/toolkit/AGENTS.md',
    description: 'An agent-neutral convention file for Cursor, Codex, Cline, Aider, Copilot, and whatever your team adds next.'
  }
];

const relatedPaths = [
  { pillar: 'Readiness', href: '/articles/how-to-know-if-your-business-is-ready-for-ai', label: 'Start with the readiness spectrum' },
  { pillar: 'Context', href: '/articles/context-engineering-ai-coding-tools', label: 'Build the shared context layer' },
  { pillar: 'ROI', href: '/articles/automation-cost-small-business', label: 'Use the cost math before you build' }
];

const playbookSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "The AI Adoption Playbook for Engineering Teams",
      "description": "A practical AI adoption playbook for engineering teams: readiness, context engineering, tool selection, pilot failure modes, and ROI math.",
      "author": {
        "@type": "Person",
        "name": "Collin Wilkins",
        "url": "https://collinwilkins.com/about"
      },
      "datePublished": "2026-04-10",
      "dateModified": "2026-05-21",
      "publisher": {
        "@type": "Person",
        "name": "Collin Wilkins"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://collinwilkins.com/guides/ai-adoption-playbook"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://collinwilkins.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Guides",
          "item": "https://collinwilkins.com/guides"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "AI Adoption Playbook",
          "item": "https://collinwilkins.com/guides/ai-adoption-playbook"
        }
      ]
    }
  ]
};
---

<Layout
  title="The AI Adoption Playbook for Engineering Teams | Collin Wilkins"
  description="A practical AI adoption playbook for engineering teams: readiness, context engineering, tool selection, pilot failure modes, and ROI math."
  schema={playbookSchema}
>
  <article class="container mx-auto max-w-5xl px-4 pt-24 md:pt-32 pb-16">

    <!-- ── Hero ── -->
    <header class="mx-auto mb-14 max-w-3xl text-center md:mb-16">
      <div class="text-xs uppercase tracking-[0.2em] text-moonlight-text-faint mb-4">Guide</div>
      <h1 class="text-3xl md:text-5xl font-serif font-bold text-[var(--color-text-primary)] leading-[1.15] mb-6">
        The AI Adoption Playbook for Engineering Teams
      </h1>
      <p class="text-lg md:text-xl text-moonlight-text-secondary max-w-2xl mx-auto leading-relaxed">
        Five problems engineering leaders hit when AI coding tools move from individual experiments to team practice.
      </p>
      <p class="mt-4 text-sm text-moonlight-text-muted">
        Free to read. Worksheet and templates download directly. Email is optional.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/toolkit/AI-Readiness-Worksheet.xlsx" download data-playbook-download data-resource="ai-readiness-worksheet" data-format="xlsx" data-access-type="download_free" class="inline-flex min-h-12 items-center justify-center rounded-lg bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--color-accent-hover)]">
          Download the worksheet
        </a>
        <a href="#toolkit" class="inline-flex min-h-12 items-center justify-center rounded-lg border border-[var(--color-border)] px-5 py-3 text-sm font-semibold text-[var(--color-text-secondary)] transition hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-primary)]">
          Get the templates
        </a>
      </div>
    </header>

    <section class="mb-16 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-8">
      <h2 class="mb-6 text-sm font-semibold uppercase tracking-[0.12em] text-[var(--color-accent)]">Pillar Map</h2>
      <div class="grid gap-4 md:grid-cols-5">
        {chapters.map((chapter) => (
          <a href={`#${chapter.id}`} data-playbook-toc data-chapter={chapter.number} data-pillar={chapter.pillar} class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-4 transition hover:border-[var(--color-border-hover)]">
            <div class="text-xs font-mono text-[var(--color-accent)]">{chapter.number}</div>
            <div class="mt-2 text-sm font-semibold text-[var(--color-text-primary)]">{chapter.pillar}</div>
            <div class="mt-1 text-xs leading-relaxed text-moonlight-text-muted">{chapter.title}</div>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="mb-6 text-2xl font-serif font-bold text-[var(--color-text-primary)] md:text-3xl">Guide Index</h2>
      <div class="overflow-hidden rounded-lg border border-[var(--color-border)]">
        {chapters.map((chapter) => (
          <a href={chapter.href} data-playbook-article data-article={chapter.href} data-chapter={chapter.number} data-pillar={chapter.pillar} class="grid gap-3 border-b border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition last:border-b-0 hover:bg-[var(--color-surface-hover)] md:grid-cols-[80px_minmax(0,1fr)_120px_90px] md:items-center">
            <div class="font-mono text-xs text-[var(--color-accent)]">Chapter {chapter.number}</div>
            <div>
              <div class="font-semibold text-[var(--color-text-primary)]">{chapter.title}</div>
              <div class="mt-1 text-sm text-moonlight-text-secondary">{chapter.coreQuestion}</div>
            </div>
            <div class="text-sm text-moonlight-text-muted">{chapter.pillar}</div>
            <div class="text-sm text-moonlight-text-muted">{chapter.readTime}</div>
          </a>
        ))}
      </div>
    </section>

    <div class="mx-auto max-w-3xl">
      {chapters.map((chapter) => (
        <>
          <section id={chapter.id} class="mb-16 scroll-mt-24">
            <div class="mb-3 text-sm font-semibold uppercase tracking-[0.12em] text-[var(--color-accent)]">Chapter {chapter.number} · {chapter.pillar}</div>
            <h2 class="mb-6 text-2xl font-serif font-bold text-[var(--color-text-primary)] md:text-3xl">{chapter.title}</h2>
            <div class="mb-6 rounded-lg border border-[var(--color-accent-border)] bg-[var(--color-accent-muted)] p-5">
              <div class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-accent)]">Key takeaway</div>
              <p class="text-sm leading-relaxed text-[var(--color-text-primary)]">{chapter.takeaway}</p>
            </div>
            <div class="prose prose-invert max-w-none text-moonlight-text-secondary leading-relaxed">
              {chapter.summary.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            <div class="mt-6 flex flex-col gap-2">
              {chapter.links.map((link) => (
                <a href={link.href} data-playbook-article data-article={link.href} data-chapter={chapter.number} data-pillar={chapter.pillar} class="font-semibold text-[var(--color-accent)] transition hover:text-[var(--color-accent-hover)]">
                  {link.label} &rarr;
                </a>
              ))}
            </div>
          </section>
          <div class="my-16 h-px bg-[var(--color-border)]"></div>
        </>
      ))}
    </div>

    <!-- ── Toolkit Form ── -->
    <section id="toolkit" class="mb-16 scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-serif font-bold text-[var(--color-text-primary)] mb-6">Get the Toolkit</h2>

      <p class="mb-8 max-w-2xl text-moonlight-text-secondary">
        These are direct downloads. No email required, no hidden bundle, no upsell.
      </p>

      <div class="mb-10 grid gap-4 md:grid-cols-3">
        {resources.map((resource) => (
          <a href={resource.href} download data-playbook-download data-resource={resource.resource} data-format={resource.format} data-access-type={resource.accessType} class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-hover)]">
            <span class="inline-flex rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-semibold text-[var(--color-text-secondary)]">{resource.label}</span>
            <h3 class="mt-4 text-lg font-serif font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)]">{resource.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-moonlight-text-secondary">{resource.description}</p>
            <p class="mt-4 text-xs font-mono uppercase tracking-[0.12em] text-moonlight-text-faint">{resource.format}</p>
          </a>
        ))}
      </div>

      <div class="p-6 md:p-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]">
        <h3 class="mb-2 text-xl font-serif font-bold text-[var(--color-text-primary)]">Email optional: future field notes</h3>
        <p class="mb-5 text-sm leading-relaxed text-moonlight-text-secondary">
          Subscribe if you want occasional notes on AI tooling, adoption patterns, and new resources. The downloads above work either way.
        </p>
        <form
          id="toolkit-form"
          class="flex flex-col sm:flex-row gap-3"
        >
          <input type="hidden" name="tag" value="playbook-toolkit" />
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            aria-label="Email address"
            class="flex-1 px-4 py-3 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text-primary)] placeholder-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all duration-300 whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p class="text-xs text-moonlight-text-muted mt-3">Newsletter subscription. Unsubscribe anytime.</p>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-6 text-2xl font-serif font-bold text-[var(--color-text-primary)] md:text-3xl">Related Paths</h2>
      <div class="grid gap-4 md:grid-cols-3">
        {relatedPaths.map((path) => (
          <a href={path.href} data-playbook-article data-article={path.href} data-chapter="related" data-pillar={path.pillar} class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-hover)]">
            <div class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-accent)]">{path.pillar}</div>
            <div class="text-sm font-semibold text-[var(--color-text-primary)]">{path.label} &rarr;</div>
          </a>
        ))}
      </div>
    </section>

  </article>
</Layout>

<script>
  function trackPlaybookEvent(name, props) {
    if (typeof window !== 'undefined' && typeof window.plausible === 'function') {
      window.plausible(name, { props });
    }
  }

  document.querySelectorAll('[data-playbook-toc]').forEach((link) => {
    link.addEventListener('click', () => {
      trackPlaybookEvent('Playbook TOC Click', {
        chapter: link.getAttribute('data-chapter'),
        pillar: link.getAttribute('data-pillar')
      });
    });
  });

  document.querySelectorAll('[data-playbook-article]').forEach((link) => {
    link.addEventListener('click', () => {
      trackPlaybookEvent('Playbook Article Click', {
        article: link.getAttribute('data-article'),
        chapter: link.getAttribute('data-chapter'),
        pillar: link.getAttribute('data-pillar'),
        access_type: 'read_free'
      });
    });
  });

  document.querySelectorAll('[data-playbook-download]').forEach((link) => {
    link.addEventListener('click', () => {
      trackPlaybookEvent('Toolkit Download Click', {
        resource: link.getAttribute('data-resource'),
        format: link.getAttribute('data-format'),
        access_type: link.getAttribute('data-access-type')
      });
    });
  });

  const form = document.getElementById('toolkit-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const email = (form.querySelector('input[type="email"]') as HTMLInputElement).value;
      const data = new FormData();
      data.append('email', email);
      data.append('tag', 'playbook-toolkit');
      navigator.sendBeacon(
        'https://buttondown.com/api/emails/embed-subscribe/collinwilkins',
        data
      );
      trackPlaybookEvent('Toolkit Email Submit', {
        location: 'playbook_toolkit',
        tag: 'playbook-toolkit',
        access_type: 'newsletter_subscription'
      });
      trackPlaybookEvent('Newsletter Subscribe', {
        location: 'playbook_toolkit'
      });
      window.location.href = '/guides/ai-adoption-playbook/thanks';
    });
  }
</script>
