---
import Layout from '../../../layouts/Layout.astro';

const downloads = [
  {
    title: 'AI Readiness Diagnostic Worksheet',
    href: '/toolkit/AI-Readiness-Worksheet.xlsx',
    resource: 'ai-readiness-worksheet',
    format: 'xlsx',
    description: 'Start here if you want a team conversation about readiness level, ownership, and next steps.'
  },
  {
    title: 'CLAUDE.md Template',
    href: '/toolkit/CLAUDE.md',
    resource: 'claude-md-template',
    format: 'md',
    description: 'Use this when Claude Code is the main coding assistant in the repo.'
  },
  {
    title: 'AGENTS.md Template',
    href: '/toolkit/AGENTS.md',
    resource: 'agents-md-template',
    format: 'md',
    description: 'Use this as the shared, agent-neutral operating contract across tools.'
  }
];
---

<Layout
  title="Toolkit | AI Adoption Playbook | Collin Wilkins"
  description="Download your AI adoption toolkit: AI Readiness Worksheet, CLAUDE.md template, and AGENTS.md template with scope, safety, memory, and stack rules."
>
  <article class="container mx-auto max-w-3xl px-4 pt-24 md:pt-32 pb-16">

    <header class="mb-12">
      <div class="text-xs uppercase tracking-[0.2em] text-moonlight-text-faint mb-4">Toolkit</div>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-[var(--color-text-primary)] leading-[1.15] mb-4">
        Use the toolkit with your team.
      </h1>
      <p class="text-lg text-moonlight-text-secondary">
        The same files are always free to download. This page is the quick-start version: what to open first and how to use each file.
      </p>
    </header>

    <section class="mb-12 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <h2 class="mb-4 text-xl font-serif font-bold text-[var(--color-text-primary)]">Suggested order</h2>
      <ol class="space-y-3 text-sm leading-relaxed text-moonlight-text-secondary">
        <li><strong class="text-[var(--color-text-primary)]">1. Score readiness together.</strong> Use the worksheet in a 20-30 minute team conversation. Disagreement is useful signal.</li>
        <li><strong class="text-[var(--color-text-primary)]">2. Pick one repo.</strong> Add a convention file where AI coding output currently varies the most.</li>
        <li><strong class="text-[var(--color-text-primary)]">3. Review it like code.</strong> Keep context, commands, safety stops, and verification expectations current.</li>
      </ol>
    </section>

    <div class="space-y-4 mb-16">
      {downloads.map((item) => (
        <a
          href={item.href}
          download
          data-thanks-download
          data-resource={item.resource}
          data-format={item.format}
          class="block p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent-border)] hover:bg-[var(--color-surface-hover)] transition-all duration-200 group"
        >
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-[var(--color-accent-muted)] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" />
              </svg>
            </div>
            <div class="min-w-0">
              <div class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                {item.title}
              </div>
              <div class="text-sm text-moonlight-text-secondary mt-1">
                {item.description}
              </div>
              <div class="text-xs text-moonlight-text-faint mt-2">{item.format.toUpperCase()} · Download free</div>
            </div>
          </div>
        </a>
      ))}

    </div>

    <div class="h-px bg-[var(--color-border)] my-12"></div>

    <p class="text-moonlight-text-secondary mb-12">
      Want occasional essays on AI tooling, agents, and automation? I publish about every other week at
      <a href="https://collinwilkins.com" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">collinwilkins.com</a>. No spam, unsubscribe anytime.
    </p>

    <a
      href="/guides/ai-adoption-playbook"
      class="text-sm text-moonlight-text-secondary hover:text-[var(--color-accent)] transition-colors"
    >
      &larr; Back to the playbook
    </a>

  </article>
</Layout>

<script>
  function trackThanksEvent(name, props) {
    if (typeof window !== 'undefined' && typeof window.plausible === 'function') {
      window.plausible(name, { props });
    }
  }

  document.querySelectorAll('[data-thanks-download]').forEach((link) => {
    link.addEventListener('click', () => {
      trackThanksEvent('Thanks Download Click', {
        resource: link.getAttribute('data-resource'),
        format: link.getAttribute('data-format'),
        access_type: 'download_after_email'
      });
    });
  });
</script>
