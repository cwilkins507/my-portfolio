---
import Layout from '../layouts/Layout.astro';
import Services from '../components/Services';

const servicesSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"name": "Services | Collin Wilkins",
	"description": "Independent practitioner work — AI coding tool adoption, convention files, and automation architecture. Limited to ~3–4 hours per week. Paid intake with written action plan.",
	"url": "https://collinwilkins.com/services",
	"provider": {
		"@type": "Person",
		"name": "Collin Wilkins",
		"url": "https://collinwilkins.com/about"
	},
	"hasOfferCatalog": {
		"@type": "OfferCatalog",
		"name": "Services",
		"itemListElement": [
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "AI coding tool adoption",
					"description": "Tool selection, rollout plans, and practitioner workshops for engineering teams (up to 20 engineers) adopting Claude Code, Cursor, or Copilot."
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Convention files (CLAUDE.md, AGENTS.md)",
					"description": "CLAUDE.md, AGENTS.md, and tool-specific rules built against your actual codebase — not generic templates."
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Automation architecture",
					"description": "Python, APIs, data pipelines, AWS Lambda, n8n. Production-grade automation systems built end to end."
				}
			},
			{
				"@type": "Offer",
				"price": "99",
				"priceCurrency": "USD",
				"itemOffered": {
					"@type": "Service",
					"name": "AI Readiness Assessment (soft-launch pricing)",
					"description": "1-hour working call plus a 3-artifact deliverable bundle: written action plan with diagnosed readiness level and 3-4 highest-ROI next steps, custom AI Adoption Playbook adapted to your stack, and a ready-to-commit AGENTS.md tailored to your codebase. Running the first 5 at $99; $250 after. Rolls into first invoice if we scope a larger project."
				}
			},
			{
				"@type": "Offer",
				"price": "500",
				"priceCurrency": "USD",
				"itemOffered": {
					"@type": "Service",
					"name": "Paid intake",
					"description": "45-minute intake call plus async brief and written action plan delivered within 48 hours. Rolls into first invoice if we scope a project. Refunded if the plan doesn't identify meaningful opportunity."
				}
			}
		]
	}
};

const servicesFaqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "What's the AI Readiness Assessment?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "A focused 1-hour working call for engineering leaders, plus a 3-artifact deliverable bundle: a written action plan with your team's diagnosed readiness level and the 3-4 highest-ROI next steps, a custom AI Adoption Playbook adapted to your stack, and a ready-to-commit AGENTS.md tailored to your codebase. Running the first 5 at $99 to build case studies. After that, $250. Rolls into the first invoice if we scope a larger project."
			}
		},
		{
			"@type": "Question",
			"name": "How much does the intake call cost?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "The paid intake is $500 for approximately 45 minutes of live call time, plus an async brief you send before the call and a written action plan delivered within 48 hours afterward. If we scope a project together, the $500 intake fee rolls into the first invoice."
			}
		},
		{
			"@type": "Question",
			"name": "What do I get from the intake?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "A written action plan delivered within 48 hours of the call: what I would do, in what order, with rough scope and pricing. The plan is yours to keep whether or not we work together. If the plan does not identify meaningful automation savings or a clear path forward, the $500 fee is refunded — I don't reshape the problem to fit a billable engagement."
			}
		},
		{
			"@type": "Question",
			"name": "What kinds of problems do you take on?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Three categories: AI coding tool adoption (standardizing Claude Code, Cursor, or Copilot across engineering teams up to 20 engineers), convention files for AI coding tools (CLAUDE.md and AGENTS.md committed to your repo, built against your actual codebase), and automation architecture (Python, APIs, AWS Lambda, n8n — the same patterns that cut $5 million in annual operational costs at Ford Motor Company)."
			}
		},
		{
			"@type": "Question",
			"name": "How much availability do you have?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Typically three to four hours per week. This is a practitioner side project, not a full consultancy. It works best for teams with a clear problem and the authority to move on it quickly — not open-ended discovery engagements or six-month scoping phases."
			}
		},
		{
			"@type": "Question",
			"name": "Why can't you take work in certain industries?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "I cannot take engagements in investment management, wealth advisory, retirement solutions, ESG data, credit ratings, or compliance software for financial services due to a conflict with my current employer. This restriction is non-negotiable, even for work that would otherwise be a great fit."
			}
		}
	]
};
---

<Layout
	title="Services | Collin Wilkins"
	description="Independent practitioner work — AI coding tool adoption, convention files, and automation architecture. Limited to ~3–4 hours per week. Paid intake with written action plan."
	schema={[servicesSchema, servicesFaqSchema]}
>
	<Services />
</Layout>
