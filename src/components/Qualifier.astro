---
/* Dormant — renders only when FUNNEL_MODE === 'full'. Built for B-graduation. */
---
<section style="padding:clamp(44px,6vw,66px) 0;border-bottom:1px solid var(--rule);">
  <div class="wrap">
    <p class="label" style="color:var(--accent);margin-bottom:28px;">This is for you if —</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,40px);">
      <div style="border-top:2px solid var(--ink);padding-top:18px;">
        <span style="font-family:var(--mono);font-size:12px;color:var(--ink-faint);letter-spacing:.06em;display:block;margin-bottom:11px;">01</span>
        <p style="font-size:16.5px;line-height:1.5;color:var(--ink-soft);text-wrap:pretty;">Your team is <strong style="color:var(--ink);font-weight:600;">past AI demos but stuck before production</strong> — prototypes that never harden into something you'd put in front of a regulated user.</p>
      </div>
      <div style="border-top:2px solid var(--ink);padding-top:18px;">
        <span style="font-family:var(--mono);font-size:12px;color:var(--ink-faint);letter-spacing:.06em;display:block;margin-bottom:11px;">02</span>
        <p style="font-size:16.5px;line-height:1.5;color:var(--ink-soft);text-wrap:pretty;">You ship in <strong style="color:var(--ink);font-weight:600;">regulated, high-stakes environments</strong>, where an AI feature has to be correct, explainable, and maintainable — not just impressive.</p>
      </div>
      <div style="border-top:2px solid var(--ink);padding-top:18px;">
        <span style="font-family:var(--mono);font-size:12px;color:var(--ink-faint);letter-spacing:.06em;display:block;margin-bottom:11px;">03</span>
        <p style="font-size:16.5px;line-height:1.5;color:var(--ink-soft);text-wrap:pretty;">You'd rather your <strong style="color:var(--ink);font-weight:600;">own engineers own the system</strong> than stay dependent on a vendor you can't see inside.</p>
      </div>
    </div>
  </div>
</section>
